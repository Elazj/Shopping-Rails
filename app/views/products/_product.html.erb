<%= link_to product do %>
  <div id="dom_id product" class="w-full sm:w-auto my-5 space-y-5">
    <%= image_tag product.images.first, class: "w-full h-90 object-cover cursor-pointer rounded-lg hover:brightness-75 transition-all duration-250" if product.images.any? %>
    <p class="text-lg text-center"><%= product.name %></p>
    <p class="text-lg text-center"><%= number_to_currency(product.price) %></p>
    <%# <p><strong class="block font-medium mb-1">Description:</strong> <%= product.description %><%#=</p> %>
  </div>
<% end %>






